{
  "name": "10m-native",
  "nodes": [
    {
      "id": "ingest",
      "type": "data.jsIngestion",
      "position": { "x": 40, "y": 200 },
      "params": { "dataset": "codeparrot/github-code-clean", "config": "javascript", "maxDocs": 2000, "maxDocChars": 40000 }
    },
    {
      "id": "tokenize",
      "type": "tokenizer.byteBpe",
      "position": { "x": 300, "y": 200 },
      "params": { "vocabSize": 16384, "trainSampleChars": 600000, "maxTokens": 8000000, "outFile": "tokens/js-10m.bin" }
    },
    {
      "id": "arch",
      "type": "model.architecture",
      "position": { "x": 560, "y": 200 },
      "params": { "dModel": 512, "hiddenDim": 2048, "contextLength": 128, "mixer": "causal-mean", "loss": "cross-entropy" }
    },
    {
      "id": "train",
      "type": "train.poc",
      "position": { "x": 820, "y": 200 },
      "params": { "steps": 50, "batchSize": 2, "lr": 0.002 }
    },
    {
      "id": "eval",
      "type": "eval.basic",
      "position": { "x": 1080, "y": 200 },
      "params": { "evalBatches": 4, "batchSize": 2 }
    },
    {
      "id": "export",
      "type": "export.binary",
      "position": { "x": 1340, "y": 200 },
      "params": { "outFile": "exports/tinylm-10m" }
    }
  ],
  "edges": [
    { "from": { "node": "ingest", "port": "text" }, "to": { "node": "tokenize", "port": "text" } },
    { "from": { "node": "tokenize", "port": "tokens" }, "to": { "node": "arch", "port": "tokens" } },
    { "from": { "node": "arch", "port": "config" }, "to": { "node": "train", "port": "config" } },
    { "from": { "node": "arch", "port": "tokens" }, "to": { "node": "train", "port": "tokens" } },
    { "from": { "node": "train", "port": "model" }, "to": { "node": "eval", "port": "model" } },
    { "from": { "node": "arch", "port": "tokens" }, "to": { "node": "eval", "port": "tokens" } },
    { "from": { "node": "tokenize", "port": "tokenizer" }, "to": { "node": "eval", "port": "tokenizer" } },
    { "from": { "node": "tokenize", "port": "tokenizer" }, "to": { "node": "export", "port": "tokenizer" } },
    { "from": { "node": "eval", "port": "model" }, "to": { "node": "export", "port": "model" } }
  ]
}
